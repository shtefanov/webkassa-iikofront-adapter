  "fiscalization": {
    "protocolVersion": "2.0.3",
    "writeFiscalData": true
  },
  "webnkt": {
    "enabled": false,
    "requireIdentifier": false
  },
  "storage": {
    "provider": "json",
    "path": "fiscal-results.json"
  },
  "offline": {
    "enabled": false,
    "maxOfflineHours": 72,
    "syncOnReconnect": true
  },
  "logging": {
    "level": "info",
    "redactSecrets": true,
    "retentionDays": 30
  },
  "licenseMonitoring": {
    "enabled": true,
    "warningDays": 7
  }
}
