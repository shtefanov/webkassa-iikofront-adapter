{
  "environment": "dev",
  "baseUrl": "https://devkkm.webkassa.kz",
  "companyProfile": "demo-company",
  "cashboxes": [
    {
      "name": "test-cashbox",
      "cashboxUniqueNumber": "SWK00035753",
      "authMode": "apiKeyAndLoginPassword",
      "apiKeySecretRef": "Webkassa test API key - SWK00035753",
      "loginSecretRef": "Webkassa test login - SWK00035753",
      "defaultUnitCode": 796,
      "defaultRoundType": 2,
      "defaultPaymentType": 0,
      "paymentTypeMap": {}
    }
  ],
  "requestPolicy": {
    "serializePerCashbox": true,
    "timeoutMs": 30000,
    "recoveryAttempts": 3,
    "recoveryDelayMs": 1000,
    "maxAlternativeHosts": 3,
    "maxRetries": 0,
    "retryOnlyWithExternalCheckNumber": true
